# URL du backend NestJS (sans slash final)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Clé de chiffrement pour redux-persist (CryptoJS) — générer une chaîne aléatoire longue
NEXT_PUBLIC_CRYPTO_SECRET=changeme_use_a_long_random_string_here

# URL publique du frontend (utilisée pour sitemap.xml et robots.txt)
NEXT_PUBLIC_SITE_URL=https://ton-domaine.com
